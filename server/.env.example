# ============================================
# TESSERACT Server Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================

# Server Port
PORT=3000

# MongoDB Connection Strings
# Usado por server.js (mongoose)
MONGO_URI=mongodb://localhost:27017/tesseract
# Usado por create-admin.js (MongoClient directo)
MONGODB_URI=mongodb+srv://TU_USUARIO:TU_PASSWORD@cluster.mongodb.net/tesseract?retryWrites=true&w=majority

# JWT Secret - Usado por middleware/auth.js
JWT_SECRET=genera_un_secreto_aqui

# Admin Account
TESS_ADMIN_EMAIL=admin@tudominio.com
TESS_ADMIN_PASSWORD=CambiaEstaPassword*+

# Groq API Key
GROQ_API_KEY=tu_groq_api_key

# OpenAI API Key (fallback)
OPENAI_API_KEY=tu_openai_api_key

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_contraseña_de_aplicacion

# Demo & Premium Settings
TESS_DEMO_HOURS=24
TESS_PREMIUM_DAYS=90
