# Server Configuration
PORT=3000

# MongoDB - REEMPLAZA ESTAS CON TUS CREDENCIALES REALES
MONGODB_URI=mongodb+srv://TU_USUARIO:TU_PASSWORD@cluster.mongodb.net/tesseract

# JWT Secret - Genera una clave segura con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
TESS_JWT_SECRET=REEMPLAZA_ESTO_CON_CLAVE_GENERADA

# Admin Account
